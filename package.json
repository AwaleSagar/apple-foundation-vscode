{
  "name": "apple-foundation-vscode",
  "displayName": "Apple Foundation Models",
  "description": "Private, offline AI-assisted development powered by Apple's on-device Foundation Models. macOS only.",
  "version": "0.1.0",
  "publisher": "sagarawale",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/AwaleSagar/apple-foundation-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/AwaleSagar/apple-foundation-vscode/issues"
  },
  "homepage": "https://github.com/AwaleSagar/apple-foundation-vscode#readme",
  "keywords": [
    "apple",
    "apple-intelligence",
    "foundation-models",
    "on-device",
    "ai",
    "llm",
    "macos",
    "offline",
    "privacy"
  ],
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "engines": {
    "vscode": "^1.104.0",
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.0",
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1c1c1e",
    "theme": "dark"
  },
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "Chat works everywhere; /commit requires a local git repository."
    },
    "untrustedWorkspaces": {
      "supported": true,
      "description": "Inference runs against a machine-scoped local bridge; workspaces cannot influence which executable is spawned."
    }
  },
  "activationEvents": [],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "apple-foundation",
        "displayName": "Apple Foundation Models",
        "managementCommand": "appleFoundation.manage"
      }
    ],
    "chatParticipants": [
      {
        "id": "apple-foundation.chat",
        "name": "apple",
        "fullName": "Apple On-Device Model",
        "description": "Private, offline, on-device help \u2014 explain, document, and write commits",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "Explain the selected code or a concept"
          },
          {
            "name": "doc",
            "description": "Generate a documentation comment for the selection"
          },
          {
            "name": "commit",
            "description": "Write a Conventional Commit message from staged changes"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "appleFoundation.manage",
        "title": "Manage Provider",
        "category": "Apple Foundation Models"
      },
      {
        "command": "appleFoundation.showStatus",
        "title": "Show Status",
        "category": "Apple Foundation Models"
      },
      {
        "command": "appleFoundation.restartServer",
        "title": "Restart Bridge Server",
        "category": "Apple Foundation Models"
      },
      {
        "command": "appleFoundation.showLogs",
        "title": "Show Logs",
        "category": "Apple Foundation Models"
      },
      {
        "command": "appleFoundation.runOnboarding",
        "title": "Run Setup Check",
        "category": "Apple Foundation Models"
      }
    ],
    "configuration": {
      "title": "Apple Foundation Models",
      "properties": {
        "appleFoundation.bridge.executablePath": {
          "type": "string",
          "default": "fm",
          "scope": "machine",
          "markdownDescription": "Path to the bridge CLI. Defaults to the `fm` CLI preinstalled on macOS 27+. On macOS 26, set this to `afm` (install via `brew install scouzi1966/afm/afm`). Machine-scoped: cannot be set by a workspace."
        },
        "appleFoundation.bridge.port": {
          "type": "number",
          "default": 9999,
          "minimum": 1024,
          "maximum": 65535,
          "scope": "machine",
          "description": "Local port for the bridge server. The server binds to 127.0.0.1 only. Machine-scoped: cannot be set by a workspace."
        },
        "appleFoundation.bridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the bridge server when a chat request needs it."
        },
        "appleFoundation.bridge.idleTimeoutMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 120,
          "description": "Stop a bridge process this extension started after this many minutes idle. 0 disables idle shutdown. Never kills a user-started bridge."
        },
        "appleFoundation.model.maxOutputTokens": {
          "type": "number",
          "default": 1024,
          "minimum": 16,
          "maximum": 8192,
          "description": "Maximum tokens the model may produce per response."
        },
        "appleFoundation.model.maxContextTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 512,
          "maximum": 32768,
          "markdownDescription": "Shared context window (input + output) used for budgeting. Raise if your on-device model reports a larger window; lower on memory-constrained machines."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "pnpm run check && pnpm run typecheck && pnpm run test",
    "package": "vsce package --no-dependencies --target darwin-arm64",
    "publish:marketplace": "vsce publish --no-dependencies --target darwin-arm64",
    "changeset": "changeset",
    "version": "changeset version",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/node": "^24.0.0",
    "@types/vscode": "~1.104.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.1.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}

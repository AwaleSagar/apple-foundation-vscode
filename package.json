{
  "name": "apple-foundation-vscode",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.0",
  "publisher": "sagarawale",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/AwaleSagar/apple-foundation-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/AwaleSagar/apple-foundation-vscode/issues"
  },
  "homepage": "https://github.com/AwaleSagar/apple-foundation-vscode#readme",
  "keywords": [
    "apple",
    "apple-intelligence",
    "foundation-models",
    "on-device",
    "ai",
    "llm",
    "macos",
    "offline",
    "privacy"
  ],
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "engines": {
    "vscode": "^1.104.0",
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.0",
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1c1c1e",
    "theme": "dark"
  },
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "Chat works everywhere; /commit requires a local git repository."
    },
    "untrustedWorkspaces": {
      "supported": true,
      "description": "Inference runs against a machine-scoped local bridge; workspaces cannot influence which executable is spawned."
    }
  },
  "activationEvents": [],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "apple-foundation",
        "displayName": "%displayName%",
        "managementCommand": "appleFoundation.manage"
      }
    ],
    "chatParticipants": [
      {
        "id": "apple-foundation.chat",
        "name": "apple",
        "fullName": "%participant.fullName%",
        "description": "%participant.description%",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "%participant.explain.description%"
          },
          {
            "name": "doc",
            "description": "%participant.doc.description%"
          },
          {
            "name": "commit",
            "description": "%participant.commit.description%"
          },
          {
            "name": "edit",
            "description": "%participant.edit.description%"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "appleFoundation.manage",
        "title": "%command.manage.title%",
        "category": "%category%"
      },
      {
        "command": "appleFoundation.showStatus",
        "title": "%command.showStatus.title%",
        "category": "%category%"
      },
      {
        "command": "appleFoundation.restartServer",
        "title": "%command.restartServer.title%",
        "category": "%category%"
      },
      {
        "command": "appleFoundation.showLogs",
        "title": "%command.showLogs.title%",
        "category": "%category%"
      },
      {
        "command": "appleFoundation.runOnboarding",
        "title": "%command.runOnboarding.title%",
        "category": "%category%"
      },
      {
        "command": "appleFoundation.editing.applyPlan",
        "title": "%command.editing.applyPlan.title%",
        "category": "%category%"
      },
      {
        "command": "appleFoundation.editing.rejectPlan",
        "title": "%command.editing.rejectPlan.title%",
        "category": "%category%"
      },
      {
        "command": "appleFoundation.editing.reviewDiff",
        "title": "%command.editing.reviewDiff.title%",
        "category": "%category%"
      },
      {
        "command": "appleFoundation.editing.rollbackLast",
        "title": "%command.editing.rollbackLast.title%",
        "category": "%category%"
      }
    ],
    "walkthroughs": [
      {
        "id": "appleFoundation.gettingStarted",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "checkSetup",
            "title": "%walkthrough.checkSetup.title%",
            "description": "%walkthrough.checkSetup.description%",
            "media": {
              "markdown": "media/walkthrough/check-setup.md"
            },
            "completionEvents": [
              "onCommand:appleFoundation.runOnboarding"
            ]
          },
          {
            "id": "pickModel",
            "title": "%walkthrough.pickModel.title%",
            "description": "%walkthrough.pickModel.description%",
            "media": {
              "markdown": "media/walkthrough/pick-model.md"
            },
            "completionEvents": [
              "onCommand:workbench.action.chat.open"
            ]
          },
          {
            "id": "tryApple",
            "title": "%walkthrough.tryApple.title%",
            "description": "%walkthrough.tryApple.description%",
            "media": {
              "markdown": "media/walkthrough/try-apple.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%displayName%",
      "properties": {
        "appleFoundation.bridge.executablePath": {
          "type": "string",
          "default": "fm",
          "scope": "machine",
          "markdownDescription": "%config.executablePath.description%"
        },
        "appleFoundation.bridge.port": {
          "type": "number",
          "default": 9999,
          "minimum": 1024,
          "maximum": 65535,
          "scope": "machine",
          "description": "%config.port.description%"
        },
        "appleFoundation.bridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoStart.description%"
        },
        "appleFoundation.bridge.idleTimeoutMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 120,
          "description": "%config.idleTimeoutMinutes.description%"
        },
        "appleFoundation.model.maxOutputTokens": {
          "type": "number",
          "default": 1024,
          "minimum": 16,
          "maximum": 8192,
          "description": "%config.maxOutputTokens.description%"
        },
        "appleFoundation.model.maxContextTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 512,
          "maximum": 32768,
          "markdownDescription": "%config.maxContextTokens.description%"
        },
        "appleFoundation.offlineOnlyMode": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.offlineOnlyMode.description%"
        },
        "appleFoundation.editing.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.editing.enabled.description%"
        },
        "appleFoundation.editing.requireConfirmation": {
          "type": "boolean",
          "default": true,
          "description": "%config.editing.requireConfirmation.description%"
        },
        "appleFoundation.editing.maxFilesPerPlan": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "%config.editing.maxFilesPerPlan.description%"
        },
        "appleFoundation.editing.maxHunksPerFile": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "%config.editing.maxHunksPerFile.description%"
        },
        "appleFoundation.editing.maxWholeFileLines": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "maximum": 2000,
          "description": "%config.editing.maxWholeFileLines.description%"
        },
        "appleFoundation.editing.allowFuzzyMatch": {
          "type": "boolean",
          "default": true,
          "description": "%config.editing.allowFuzzyMatch.description%"
        },
        "appleFoundation.editing.deniedGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.env*",
            "**/.env",
            "**/secrets/**",
            "**/*.pem",
            "**/*.key"
          ],
          "description": "%config.editing.deniedGlobs.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:vscode": "node esbuild.mjs && node esbuild.mjs --tests && VSCODE_TEST=true vscode-test",
    "verify": "pnpm run check && pnpm run typecheck && pnpm run test",
    "package": "vsce package --no-dependencies --target darwin-arm64",
    "publish:marketplace": "vsce publish --no-dependencies --target darwin-arm64",
    "changeset": "changeset",
    "version": "changeset version",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "~1.104.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.1.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
